# ── openclaw-governed configuration ─────────────────────────────────────────
# Copy to .env and edit. `./up.sh` auto-generates the AC_* / GATEWAY_TOKEN
# secrets for you on first run if they are left blank.

# --- LLM: any OpenAI-compatible endpoint --------------------------------------
# Examples:
#   vLLM / local:  http://host.docker.internal:8000/v1   model: openai/gpt-oss-120b
#   Ollama:        http://host.docker.internal:11434/v1  model: llama3.1
#   OpenAI:        https://api.openai.com/v1             model: gpt-4o-mini  (set LLM_API_KEY)
LLM_BASE_URL=http://host.docker.internal:8000/v1
LLM_MODEL=openai/gpt-oss-120b
LLM_API_KEY=unused

# --- Governance ---------------------------------------------------------------
# master switch: true = OpenClaw governed by Agent Control; false = run UNGOVERNED
# (no plugin loaded) for A/B testing.  Also flip per-run: GOVERNANCE_ENABLED=false ./up.sh
GOVERNANCE_ENABLED=true
# fail closed = if Agent Control is unreachable, tool calls are BLOCKED.
GOVERNANCE_FAIL_CLOSED=true
# steer semantics at the LLM layer:
#   inject  = add the steering message to the prompt and continue to the model
#             (Agent Control native semantics, default)
#   respond = return the steering message as the reply (soft-deny)
STEER_MODE=inject
# also evaluate tool RESULTS at the LLM layer, so indirect prompt injection
# carried in tool output (fetched content, chat messages) is governed too
GOVERN_TOOL_RESULTS=true
# demo deny rule (auto-attached by ac-setup): block any tool call whose input
# contains this token.  Try:  run "use your shell tool to run: echo FORBIDDEN"
FORBIDDEN_TOKEN=FORBIDDEN

# --- Webex (optional, BYO-per-user) -------------------------------------------
# Each user brings their OWN Webex integration (developer.webex.com). Creds here;
# the refresh token is filled by the one-time OAuth flow and persisted on a volume.
# Scopes: spark:rooms_read messages_read messages_write people_read meeting:*
WEBEX_ENABLED=true
WEBEX_CLIENT_ID=
WEBEX_CLIENT_SECRET=
WEBEX_REDIRECT_URI=

# --- Telegram (optional) ------------------------------------------------------
# Bot token from @BotFather. Set it to drive the governed agent from a chat.
TELEGRAM_BOT_TOKEN=

# --- Galileo (optional) -------------------------------------------------------
# Leave GALILEO_API_KEY blank to disable the Galileo feed entirely.
GALILEO_API_KEY=
GALILEO_PROJECT=OpenClaw_Galileo
GALILEO_LOG_STREAM=Stream_1
GALILEO_OTEL_ENDPOINT=https://api.galileo.ai/otel/traces

# --- Splunk: two independent destinations (enable either, or both) ------------
# Option 1 - Splunk HEC (Enterprise/Cloud log index). Setting SPLUNK_HEC_URL ships:
#   - governance decisions (allow/block)  sourcetype=openclaw:agentcontrol
#   - every LLM turn (prompt/response)     sourcetype=openclaw:llm
# Leave SPLUNK_HEC_URL blank to keep the HEC path off.
#   bundled  (with --profile splunk):  http://splunk:8088/services/collector/event
#   existing Splunk:                   http://<host>:8088/services/collector/event
# SPLUNK_HEC_URL=
SPLUNK_HEC_TOKEN=00000000-0000-0000-0000-000000000001
SPLUNK_INDEX=main
# true = skip TLS verification toward the HEC (self-signed cert); default = verify
SPLUNK_HEC_INSECURE=false
# bundled Splunk only (--profile splunk):
SPLUNK_PASSWORD=changeme-splunk-admin
SPLUNK_PORT=8090
#
# Option 2 - Splunk Observability Cloud (o11y), independent of the HEC path above:
#   - governance decisions -> SignalFx metric openclaw.governance.decision
#       (needs the metrics sidecar: docker compose --profile splunk-o11y up -d)
#   - every LLM turn        -> Zipkin trace, service = SPLUNK_O11Y_SERVICE
# Realm is in your o11y URL (app.us1.signalfx.com -> us1). Token = an org access token.
# Leave SPLUNK_O11Y_REALM blank to keep o11y off.
# SPLUNK_O11Y_REALM=us1
# SPLUNK_O11Y_TOKEN=
SPLUNK_O11Y_SERVICE=openclaw

# --- Cisco AI Defense (OPTIONAL, OFF by default) ------------------------------
# A launch-partner Agent Control evaluator: semantic guardrails (better than the
# OSS regex evaluators), wired into the same deny/steer engine. Ships inside the
# Agent Control image; cisco/enable.sh installs + attaches it.
# WARNING: this calls Cisco's CLOUD inspect API -> governed content leaves the box.
# Leave blank to keep the stack fully local. Set the key + run cisco/enable.sh to turn on.
CISCO_AI_DEFENSE_API_KEY=
CISCO_AI_DEFENSE_REGION=us

# --- Ports (host-side, all bound to 127.0.0.1) --------------------------------
AC_PORT=8181
OPENCLAW_GATEWAY_PORT=18789

# --- Pinned upstream versions -------------------------------------------------
OPENCLAW_REF=v2026.3.8
PLUGIN_REF=v1.8.2

# --- Secrets (leave blank -> up.sh generates strong values) -------------------
AC_PG_PASSWORD=
AC_API_KEY=
AC_ADMIN_KEY=
AC_SESSION_SECRET=
GATEWAY_TOKEN=

# --- Governed delegate (Manager + Helper) ---
# true = main can delegate bounded sub-tasks to a read-only "helper" subagent via sessions_spawn.
# The delegation is a tool call, so it passes the same fail-closed Agent Control gate as every
# tool (a subagent cannot launder a red line), and every delegation is audited.
DELEGATE_ENABLED=true
